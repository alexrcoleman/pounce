{
  "name": "pounce",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"next dev\" \"ts-node-dev server/socketioMain.ts\"",
    "storybook": "storybook dev -h 127.0.0.1",
    "build-storybook": "storybook build",
    "build": "next build",
    "action-ranking:examples": "ts-node --transpile-only scripts/generateActionRankingExamples.ts",
    "action-ranking:train": "ts-node --transpile-only scripts/trainActionRankingPolicy.ts",
    "action-ranking:evaluate": "ts-node --transpile-only scripts/evaluateActionRankingPolicy.ts",
    "action-ranking:compare": "ts-node --transpile-only scripts/compareActionRankingPolicies.ts",
    "action-ranking:tune": "ts-node --transpile-only scripts/tuneActionRankingPolicy.ts",
    "start": "PORT=3000 next start -p 3000",
    "build-socketio": "echo 'no build needed for socketio server'",
    "start-socketio": "PORT=3001 ts-node --transpile-only server/socketioMain.ts",
    "test:pounce-rush": "ts-node --transpile-only shared/PounceRush.test.ts",
    "lint": "next lint"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.18.2",
    "@ant-design/icons": "^5.2.6",
    "@statsig/react-bindings": "^3.33.2",
    "antd": "^5.12.5",
    "mobx": "^6.12.0",
    "mobx-react-lite": "^4.0.5",
    "next": "^14.0.4",
    "rand-seed": "^1.0.2",
    "react": "^18.2.0",
    "react-confetti": "^6.1.0",
    "react-dnd": "^14.0.4",
    "react-dnd-html5-backend": "^14.0.2",
    "react-dnd-touch-backend": "^14.1.1",
    "react-dom": "^18.2.0",
    "socket.io": "^4.4.0",
    "socket.io-client": "^4.4.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.16.5",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/nextjs": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@types/node": "17.0.2",
    "@types/react": "17.0.37",
    "babel-loader": "^8.2.3",
    "concurrently": "^8.2.2",
    "eslint": "8.5.0",
    "eslint-plugin-storybook": "^0.11.6",
    "storybook": "^8.6.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "webpack": "^5.65.0",
    "webpack-cli": "^4.9.1"
  },
  "engines": {
    "node": ">=18.17.0"
  }
